# floor3d-card configuration — example (synthetic, mirrors floor3d-toolkit defaults).
#
# Replace the entity IDs + object_ids with your own. object_id values come
# straight from the `<name>.nodes.txt` file that `floor3d-toolkit pack`
# generates next to the GLB.
#
# Paste into a manual Lovelace card editor.

type: custom:floor3d-card
path: /local/floor3d/
objfile: home.glb
shadow: 'yes'
extralightmode: 'yes'
globalLightPower: 0.25
entities:
  # === lights (type3d: light — emits an actual PointLight) ===

  - entity: light.living_room_main
    type3d: light
    object_id: light_living_main_light
    action: more-info
    light:
      lumens: 1000
      color: '#ffffff'
      distance: 400
      shadow: 'yes'
      vertical_alignment: bottom

  - entity: switch.kitchen_main
    type3d: light
    object_id: light_kitchen_main_light
    action: more-info
    light:
      lumens: 800
      color: '#ffffff'
      distance: 350
      shadow: 'yes'
      vertical_alignment: bottom

  # === appliances / furniture (type3d: color — mesh tint changes with state) ===

  - entity: switch.refrigerator
    type3d: color
    object_id: furn_refrigerator_1
    action: more-info
    colorcondition:
      - state: 'on'
        color: '#ffc864'
      - state: 'off'
        color: '#2d3a55'

  # media_player needs more state rows than just on/off, otherwise the card
  # crashes when the entity sits in 'playing' / 'paused' / 'idle'.
  - entity: media_player.living_tv
    type3d: color
    object_id: Flat_TV_1
    action: more-info
    colorcondition:
      - state: 'playing'
        color: '#ffc864'
      - state: 'paused'
        color: '#ffc864'
      - state: 'idle'
        color: '#2d3a55'
      - state: 'off'
        color: '#2d3a55'
      - state: 'standby'
        color: '#2d3a55'
      - state: 'unavailable'
        color: '#2d3a55'
